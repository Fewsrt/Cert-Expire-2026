rules_version = '2';

// Collections: vmCa2023Cases (test definitions), vmCa2023Results (tracker + report rows).
//
// Production hardening: replace permissive rules below with Firebase Authentication
// and least-privilege writes (e.g. only admin/service accounts for writes).

service cloud.firestore {
  match /databases/{database}/documents {
    match /vmCa2023Results/{caseId} {
      allow read, create, update: if true;
      allow delete: if true;
    }

    match /vmCa2023Cases/{caseId} {
      allow read, create, update: if true;
      allow delete: if true;
    }
  }
}
