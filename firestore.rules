rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /vmCa2023Results/{caseId} {
      allow read, create, update: if true;
      allow delete: if true;
    }

    match /vmCa2023Cases/{caseId} {
      allow read, create, update: if true;
      allow delete: if true;
    }
  }
}
