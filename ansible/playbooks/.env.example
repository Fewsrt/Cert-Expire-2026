# Optional: playbook-only secrets (loaded after repo-root ../../.env by npm run ansible:assess).
# You can put ANSIBLE_PASSWORD here instead of the root .env.
#
# Copy:  cp .env.example .env
#
# Manual run (bash) from ansible/:
#   set -a && source ../../.env && source .env && set +a
#   ansible-playbook playbooks/secureboot_ca_assessment.yml
#
ANSIBLE_PASSWORD=
