# Copy to `.env` in this folder (gitignored):
#   copy .env.example .env
#
# --- Firebase / Node tools (tools/*.mjs) ---
FIREBASE_PROJECT_ID=cert-expire-2026-ca
# GOOGLE_APPLICATION_CREDENTIALS=
# FIREBASE_CLIENT_ID=
# FIREBASE_CLIENT_SECRET=
# FIREBASE_TOOLS_CONFIG=

# --- Ansible assessment (inventory + collect) ---
# Used by: npm run ansible:assess  (also export these yourself if you run ansible-playbook manually)
#
# Shared password for Linux SSH + Windows WinRM (see ansible/inventory/group_vars/all.yml)
ANSIBLE_PASSWORD=

# vCenter export CSV — path relative to ansible/ unless absolute (inventory/vcenter_csv_inventory.py)
VCENTER_CSV=samples/vcenter_targets.csv

# Only rows with this column truthy are assessed (default in inventory script: check)
# VCENTER_CHECK_COLUMN=check

# Set to true to include every CSV row even without check=true (full exports)
# VCENTER_INCLUDE_ALL=
